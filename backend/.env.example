# Server Configuration
NODE_ENV=development
PORT=3000

# Redis Configuration
# Set to 'true' to enable Redis, 'false' to use in-memory fallback
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info